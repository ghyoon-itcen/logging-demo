<?xml version="1.0" encoding="UTF-8"?>
<configuration>

	<!-- ============================================================ -->
	<!-- 공통 프로퍼티                                                  -->
	<!-- ============================================================ -->
	<property name="LOG_PATH" value="${LOG_PATH:-/app/logs}" />
	<property name="LOG_FILE" value="${LOG_FILE:-petclinic}" />
	<property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [%X{reqId:-}] [%X{method:-} %X{uri:-}] %msg%n" />

	<!-- ============================================================ -->
	<!-- 콘솔 Appender (Docker stdout으로 수집됨)                       -->
	<!-- ============================================================ -->
	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>${LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
	</appender>

	<!-- ============================================================ -->
	<!-- 파일 Appender (RollingFileAppender - 일별 롤링)                -->
	<!-- ============================================================ -->
	<appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${LOG_PATH}/${LOG_FILE}.log</file>
		<encoder>
			<pattern>${LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<!-- 일별 롤링, 최대 30일 보관 -->
			<fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>30</maxHistory>
			<totalSizeCap>1GB</totalSizeCap>
		</rollingPolicy>
	</appender>

	<!-- ============================================================ -->
	<!-- 로거 설정                                                     -->
	<!-- ============================================================ -->

	<!-- Spring Framework -->
	<logger name="org.springframework" level="INFO" />

	<!-- Hibernate SQL (필요 시 DEBUG로 변경) -->
	<logger name="org.hibernate.SQL" level="INFO" />

	<!-- ============================================================ -->
	<!-- 프로파일별 설정                                                -->
	<!-- ============================================================ -->

	<!-- 기본(개발/데모) 프로파일: 콘솔 + 파일 -->
	<springProfile name="default">
		<root level="INFO">
			<appender-ref ref="CONSOLE" />
			<appender-ref ref="FILE" />
		</root>
	</springProfile>

	<!-- 프로덕션 프로파일: 파일만 (콘솔 제외) -->
	<springProfile name="production">
		<root level="WARN">
			<appender-ref ref="FILE" />
		</root>
	</springProfile>

</configuration>
